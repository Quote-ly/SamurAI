MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
GCP_PROJECT_ID=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
VIRTUALDOJO_MCP_URL=https://dev.virtualdojo.com/mcp/v1
AYRSHARE_API_KEY=
# Directory for persistent SQLite databases (checkpoints + vector memory)
# On Cloud Run, mount a volume here. Defaults to /data if unset.
SAMURAI_DATA_DIR=/data

# Chain-of-Verification mode (hallucination mitigation; see CLAUDE.md).
# off     = disabled (default, zero overhead)
# shadow  = log what would be flagged without rejecting (collect data first)
# enforce = reject ungrounded claims, route back to agent for re-verification
SAMURAI_VERIFY_MODE=off
